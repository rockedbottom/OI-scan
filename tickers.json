const fetch = require('node-fetch');

module.exports = async (req, res) => {
  res.setHeader('Access-Control-Allow-Origin', '*');

  let tickers = [];

  // ── Source 1: NASDAQ-listed stocks ───────────────────────────────────────
  try {
    const r = await fetch(
      'https://api.nasdaq.com/api/screener/stocks?tableonly=true&limit=10000&exchange=nasdaq&download=true',
      { headers: { 'User-Agent': 'Mozilla/5.0', 'Accept': 'application/json' } }
    );
    if (r.ok) {
      const json = await r.json();
      const rows = json?.data?.table?.rows || [];
      for (const row of rows) {
        const t = row.symbol;
        if (t && !t.includes('/') && !t.includes('^') && !t.includes('~') && t.length <= 5)
          tickers.push(t.replace('.', '-'));
      }
    }
  } catch(e) { console.error('NASDAQ source failed:', e.message); }

  // ── Source 2: NYSE-listed stocks ──────────────────────────────────────────
  try {
    const r = await fetch(
      'https://api.nasdaq.com/api/screener/stocks?tableonly=true&limit=10000&exchange=nyse&download=true',
      { headers: { 'User-Agent': 'Mozilla/5.0', 'Accept': 'application/json' } }
    );
    if (r.ok) {
      const json = await r.json();
      const rows = json?.data?.table?.rows || [];
      for (const row of rows) {
        const t = row.symbol;
        if (t && !t.includes('/') && !t.includes('^') && !t.includes('~') && t.length <= 5)
          tickers.push(t.replace('.', '-'));
      }
    }
  } catch(e) { console.error('NYSE source failed:', e.message); }

  // ── Source 3: AMEX-listed stocks ──────────────────────────────────────────
  try {
    const r = await fetch(
      'https://api.nasdaq.com/api/screener/stocks?tableonly=true&limit=10000&exchange=amex&download=true',
      { headers: { 'User-Agent': 'Mozilla/5.0', 'Accept': 'application/json' } }
    );
    if (r.ok) {
      const json = await r.json();
      const rows = json?.data?.table?.rows || [];
      for (const row of rows) {
        const t = row.symbol;
        if (t && !t.includes('/') && !t.includes('^') && !t.includes('~') && t.length <= 5)
          tickers.push(t.replace('.', '-'));
      }
    }
  } catch(e) { console.error('AMEX source failed:', e.message); }

  // ── Deduplicate ───────────────────────────────────────────────────────────
  tickers = [...new Set(tickers)];

  // ── Fallback: if all sources failed, use a large hardcoded list ───────────
  if (tickers.length < 100) {
    console.log('All live sources failed — using hardcoded fallback');
    tickers = FALLBACK;
  }

  console.log(`Returning ${tickers.length} tickers`);
  res.json({ tickers, total: tickers.length });
};

